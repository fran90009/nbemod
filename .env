# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=nbemod
POSTGRES_PASSWORD=nbemod_secret
POSTGRES_DB=nbemod
DATABASE_URL=postgresql://nbemod:nbemod_secret@postgres:5432/nbemod

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=nbemod_admin
MINIO_ROOT_PASSWORD=nbemod_secret_minio
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=nbemod
MINIO_SECURE=false

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── UI ──────────────────────────────────────────────────────────────────────
API_BASE_URL=http://api:8000
